# E*Trade API credentials
# Register at developer.etrade.com to get these
ETRADE_CONSUMER_KEY=your_consumer_key_here
ETRADE_CONSUMER_SECRET=your_consumer_secret_here

# Optional: pin a specific account (otherwise uses the first account)
# ETRADE_ACCOUNT_KEY=your_account_id_key_here

# AlphaVantage API key — get a free key at https://www.alphavantage.co/support/#api-key
# Free tier (25 calls/day): covers prices + VIX for all watchlist tickers
# Premium plan: unlocks HISTORICAL_OPTIONS (real IV, delta, theta) + HISTORICAL_PUT_CALL_RATIO
ALPHAVANTAGE_API_KEY=your_key_here
